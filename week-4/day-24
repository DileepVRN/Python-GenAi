from pydantic import BaseModel
import logging

app = FastAPI()
logger = logging.getLogger(__name__)

IDEMPOTENCY_STORE = {}  # replace with Redis/DB

class TxReq(BaseModel):
    user_id: str
    amount: float

@app.post("/transactions")
async def create_tx(tx: TxReq, idempotency_key: str = Header(...)):
    if tx.amount <= 0:
        raise HTTPException(400, "Amount must be positive")

    # idempotency check
    if idempotency_key in IDEMPOTENCY_STORE:
        return IDEMPOTENCY_STORE[idempotency_key]

    try:
        # BEGIN TRANSACTION (pseudo)
        # 1) validate business rules
        # 2) insert row
        # 3) write outbox event
        result = {"id": "tx_123", "user_id": tx.user_id, "amount": tx.amount}
        # COMMIT

        IDEMPOTENCY_STORE[idempotency_key] = result
        return {"status": "success", "data": result}

    except Exception:
