import time

@app.middleware("http")
async def log_requests(request, call_next):
    start = time.time()

    response = await call_next(request)

    duration = time.time() - start
    logger.info("Request processed", extra={
        "path": request.url.path,
        "duration": duration,
        "status": response.status_code
    })

    return response
