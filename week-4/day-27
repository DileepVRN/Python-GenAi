service.py
from sqlalchemy.orm import Session
from models import Portfolio

def update_portfolio(db: Session, req):

    portfolio = db.query(Portfolio).filter_by(
        user_id=req.userId,
        stock_symbol=req.stockSymbol
    ).first()

    if not portfolio:
        portfolio = Portfolio(
            user_id=req.userId,
            stock_symbol=req.stockSymbol,
            quantity=0,
            avg_price=0
        )
        db.add(portfolio)

    # BUY LOGIC
    if req.type == "BUY":
        total_qty = portfolio.quantity + req.quantity

        avg_price = (
            (portfolio.quantity * portfolio.avg_price) +
            (req.quantity * req.price)
        ) / total_qty

        portfolio.quantity = total_qty
        portfolio.avg_price = avg_price

    # SELL LOGIC
    elif req.type == "SELL":
        if portfolio.quantity < req.quantity:
            raise Exception("Insufficient shares")

        portfolio.quantity -= req.quantity

    db.commit()
    db.refresh(portfolio)

    return portfolio
🟢 7. API Layer (FastAPI)
main.py
from fastapi import FastAPI, Depends, HTTPException
from sqlalchemy.orm import Session
from database import SessionLocal, engine, Base
import models, schemas, service

Base.metadata.create_all(bind=engine)

app = FastAPI()

def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()


@app.post("/portfolio/update")
def update_portfolio_api(req: schemas.PortfolioRequest, db: Session = Depends(get_db)):
    try:
        result = service.update_portfolio(db, req)

        return {
            "status": "SUCCESS",
            "data": {
                "userId": result.user_id,
                "stockSymbol": result.stock_symbol,
                "quantity": result.quantity,
                "avgPrice": result.avg_price
            }
        }

    except Exception as e:
        raise HTTPException(status_code=400, detail=str(e))
