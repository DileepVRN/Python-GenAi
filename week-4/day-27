@Transactional
public Portfolio updatePortfolio(PortfolioRequest req) {

    Portfolio p = repo.findByUserIdAndStockSymbol(req.getUserId(), req.getStockSymbol())
        .orElse(new Portfolio());

    if ("BUY".equals(req.getType())) {
        int totalQty = p.getQuantity() + req.getQuantity();

        double avgPrice = ((p.getQuantity() * p.getAvgPrice()) +
                          (req.getQuantity() * req.getPrice())) / totalQty;

        p.setQuantity(totalQty);
        p.setAvgPrice(avgPrice);

    } else if ("SELL".equals(req.getType())) {
        if (p.getQuantity() < req.getQuantity()) {
            throw new RuntimeException("Insufficient shares");
        }

        p.setQuantity(p.getQuantity() - req.getQuantity());
    }

    return repo.save(p);
}
