⚙️ Production-Style FastAPI Example
from fastapi import FastAPI, Query, HTTPException
from typing import Optional, List
import logging

app = FastAPI()
logger = logging.getLogger(__name__)

# pretend DB
DB = [
    {"user_id": "U1", "amount": 100, "ts": "2026-01-01"},
    {"user_id": "U1", "amount": 200, "ts": "2026-01-02"},
    {"user_id": "U2", "amount": 50,  "ts": "2026-01-02"},
]

@app.get("/transactions")
async def get_transactions(
    user_id: Optional[str] = None,
    limit: int = Query(50, le=200),
):
    try:
        data = DB

        if user_id:
            data = [d for d in data if d["user_id"] == user_id]

        # simple pagination
        data = data[:limit]

        return {
            "count": len(data),
            "data": data
        }

    except Exception as e:
        logger.error("GET /transactions failed", exc_info=True)
        raise HTTPException(status_code=500, detail="Internal error")
