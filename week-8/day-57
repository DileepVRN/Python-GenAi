Python Example – Integrating Microservices
from fastapi import FastAPI, HTTPException
import requests
import os

app = FastAPI()

USER_SERVICE_URL = os.getenv("USER_SERVICE_URL", "http://localhost:8001")
TRADE_SERVICE_URL = os.getenv("TRADE_SERVICE_URL", "http://localhost:8002")

@app.get("/user-trade-info/{user_id}")
def user_trade_info(user_id: str):
    try:
        user_resp = requests.get(f"{USER_SERVICE_URL}/user/{user_id}")
        trade_resp = requests.get(f"{TRADE_SERVICE_URL}/trades/{user_id}")
        return {
            "user": user_resp.json(),
            "trades": trade_resp.json()
        }
    except requests.exceptions.RequestException as e:
        raise HTTPException(status_code=500, detail=str(e))

GS-Level Takeaways:

Handles service failures gracefully
Uses environment variables for dynamic service URLs
Supports end-to-end microservice integration testing
