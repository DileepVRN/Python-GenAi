✅ Implementation
import logging

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

def validate_prices(prices):
    if not prices:
        raise ValueError("Empty price list")

    for p in prices:
        if p is None or p <= 0:
            raise ValueError(f"Invalid price: {p}")

def detect_trend(prices):
    if len(prices) < 2:
        return "NO SIGNAL"

    if prices[-1] > prices[-2]:
        return "BUY"
    elif prices[-1] < prices[-2]:
        return "SELL"

    return "HOLD"

def strategy_engine(prices):
    validate_prices(prices)

    signal = detect_trend(prices)

    logger.info(f"Generated signal: {signal}")

    return signal


prices = [100, 105, 110]

print(strategy_engine(prices))
