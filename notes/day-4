✅ PRODUCTION-LEVEL IMPLEMENTATION
import logging

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

MAX_LIMIT = 50000

def validate_trade(amount: float) -> None:
    if not isinstance(amount, (int, float)):
        raise TypeError("Invalid type")

    if amount <= 0:
        raise ValueError("Invalid amount")

def check_risk(amount: float) -> str:
    if amount > MAX_LIMIT:
        return "REJECT"
    return "APPROVE"

def risk_engine(amount: float) -> str:
    try:
        validate_trade(amount)

        decision = check_risk(amount)

        logger.info(f"Risk decision: {decision} for amount {amount}")

        return decision

    except Exception as e:
        logger.error(f"Risk validation failed: {e}")
        return "REJECT"
