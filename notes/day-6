⚙️ 2) RISK SERVICE (CONSUMER + RULE ENGINE)
🎯 Task

Consume from orders → apply rules → produce to approved or rejected

from kafka import KafkaConsumer, KafkaProducer
import json, logging

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger("risk")

consumer = KafkaConsumer(
    "orders",
    bootstrap_servers="localhost:9092",
    value_deserializer=lambda m: json.loads(m.decode("utf-8")),
    enable_auto_commit=True,
    group_id="risk-group"
)

producer = KafkaProducer(
    bootstrap_servers="localhost:9092",
    value_serializer=lambda v: json.dumps(v).encode("utf-8")
)

processed_ids = set()  # idempotency (demo; use Redis in prod)

def max_amount_rule(trade):
    return trade["amount"] <= 50000

def country_rule(trade):
    return trade["country"] != "restricted"

rules = [max_amount_rule, country_rule]

def evaluate(trade):
    for r in rules:
        if not r(trade):
            return False
    return True

for msg in consumer:
    trade = msg.value

    # idempotency
    if trade["trade_id"] in processed_ids:
        logger.warning(f"Duplicate: {trade['trade_id']}")
        continue

    processed_ids.add(trade["trade_id"])

    try:
        if evaluate(trade):
            producer.send("approved", trade)
            logger.info(f"APPROVED {trade['trade_id']}")
        else:
            producer.send("rejected", trade)
            logger.info(f"REJECTED {trade['trade_id']}")
    except Exception as e:
        logger.error(f"Risk error: {e}")
        producer.send("dlq", trade)  # DLQ
🏗️ 3) ORDER SERVICE (EXECUTION)
🎯 Task

Consume approved → execute trade → ensure no duplicates

from kafka import KafkaConsumer
import json, logging

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger("order")

consumer = KafkaConsumer(
    "approved",
    bootstrap_servers="localhost:9092",
    value_deserializer=lambda m: json.loads(m.decode("utf-8")),
    group_id="order-group"
)

executed_ids = set()  # idempotency

def execute(trade):
    if trade["trade_id"] in executed_ids:
        return "DUPLICATE"

    executed_ids.add(trade["trade_id"])
    logger.info(f"EXECUTED {trade['trade_id']}")
    return "EXECUTED"

for msg in consumer:
    trade = msg.value
    execute(trade)
