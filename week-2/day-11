🔹 What actually matters in production

A class is not just syntax—it’s how you model real entities + enforce rules + keep systems maintainable.

Example (Production-style Account)
import logging

logger = logging.getLogger(__name__)

class Account:
    def __init__(self, account_id: str, balance: float = 0.0):
        self._account_id = account_id
        self._balance = balance   # encapsulated

    @property
    def balance(self):
        return self._balance

    def deposit(self, amount: float):
        if amount <= 0:
            logger.warning("Invalid deposit attempt", extra={"account_id": self._account_id, "amount": amount})
            raise ValueError("Amount must be positive")

        self._balance += amount
        logger.info("Deposit successful", extra={"account_id": self._account_id, "amount": amount})

    def withdraw(self, amount: float):
        if amount <= 0:
            raise ValueError("Amount must be positive")

        if amount > self._balance:
            logger.error("Insufficient funds", extra={"account_id": self._account_id, "amount": amount})
            raise ValueError("Insufficient funds")

        self._balance -= amount
        logger.info("Withdrawal successful", extra={"account_id": self._account_id, "amount": amount})
