🟡 4. PYTHON IMPLEMENTATION (REALISTIC)
🔹 Producer (Market Feed)
import random, time, json
from kafka import KafkaProducer

producer = KafkaProducer(
    bootstrap_servers='localhost:9092',
    acks='all',
    value_serializer=lambda v: json.dumps(v).encode()
)

def generate_price():
    return round(random.uniform(3000, 4000), 2)

def publish():
    while True:
        event = {
            "symbol": "TCS",
            "price": generate_price(),
            "timestamp": time.time()
        }

        producer.send("market-topic", event)
        producer.flush()
        time.sleep(1)
🔹 Consumer (Update Cache)
from kafka import KafkaConsumer
import json

cache = {}

consumer = KafkaConsumer(
    "market-topic",
    bootstrap_servers="localhost:9092",
    group_id="market-group",
    value_deserializer=lambda x: json.loads(x.decode())
)

for msg in consumer:
    event = msg.value
    cache[event["symbol"]] = event["price"]

    print("Updated Cache:", cache)
🧠 Key Insight

👉 Cache always stores latest state
👉 Kafka stores history

