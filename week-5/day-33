🟡 4. Python Implementation (PRODUCTION THINKING)
🔹 Strategy Function
def strategy_engine(event):
    price = event["price"]

    if price < 3000:
        return "BUY"
    elif price > 3500:
        return "SELL"
    return None
🔹 Stream Processing
from kafka import KafkaConsumer, KafkaProducer
import json

consumer = KafkaConsumer(
    "market-topic",
    bootstrap_servers="localhost:9092",
    group_id="strategy-group",
    value_deserializer=lambda x: json.loads(x.decode())
)

producer = KafkaProducer(
    bootstrap_servers="localhost:9092",
    value_serializer=lambda v: json.dumps(v).encode()
)

for msg in consumer:
    event = msg.value

    action = strategy_engine(event)

    if action:
        signal = {
            "symbol": event["symbol"],
            "action": action,
            "price": event["price"]
        }

        producer.send("orders-topic", signal)
