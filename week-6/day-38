Sliding Window for Fraud Detection

from collections import deque

window_size = 3
transactions = [100, 120, 5000, 200, 210, 15000]
user_window = deque()
window_sum = 0

for txn in transactions:
    user_window.append(txn)
    window_sum += txn
    if len(user_window) > window_size:
        window_sum -= user_window.popleft()
    # compute anomaly score
    mean = window_sum / len(user_window)
    if txn > 3 * mean:  # simple threshold
        print(f"Alert: Transaction {txn} flagged as potential fraud")

