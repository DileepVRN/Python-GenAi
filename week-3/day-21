import csv
import logging
from datetime import datetime
from collections import defaultdict

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

class TransactionAnalyzer:

    def __init__(self):
        self.user_totals = defaultdict(float)
        self.user_counts = defaultdict(int)

    # ---------- READER ----------
    def read_transactions(self, file_path):
        with open(file_path) as f:
            reader = csv.DictReader(f)
            for row in reader:
                yield row

    # ---------- VALIDATION ----------
    def validate(self, row):
        try:
            if not row["user_id"] or float(row["amount"]) < 0:
                return False
            return True
        except:
            return False

    # ---------- CLEANING ----------
    def clean(self, row):
        try:
            return Transaction(
                user_id=row["user_id"].strip(),
                amount=float(row["amount"]),
                timestamp=datetime.fromisoformat(row["timestamp"]),
                status=row["status"].strip()
            )
        except Exception as e:
            logger.error("Cleaning failed", extra={"row": row})
            return None

    # ---------- PROCESS ----------
    def process(self, file_path):
        for row in self.read_transactions(file_path):
            if not self.validate(row):
                logger.warning("Invalid row skipped", extra={"row": row})
                continue

            tx = self.clean(row)
            if not tx:
                continue

            if tx.status != "SUCCESS":
                continue  # filtering

            self.aggregate(tx)

    # ---------- AGGREGATION ----------
    def aggregate(self, tx):
        self.user_totals[tx.user_id] += tx.amount
        self.user_counts[tx.user_id] += 1

    # ---------- DETECTION ----------
    def detect_suspicious(self, threshold=10000):
        return [u for u, total in self.user_totals.items() if total > threshold]

    # ---------- OUTPUT ----------
    def save_results(self, output_file):
        with open(output_file, "w") as f:
            f.write("user_id,total,count\n")
            for user in self.user_totals:
                f.write(f"{user},{self.user_totals[user]},{self.user_counts[user]}\n")
